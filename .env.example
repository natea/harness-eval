# Copy to .env and fill in. .env is gitignored; secrets are env-only by design.

# Linear API key used by built Symphony implementations during the
# real-integration bonus tier (Symphony Eval Fixtures project, Jazkarta workspace)
LINEAR_API_KEY=

# Daytona API key for sandbox provisioning (primary isolation provider)
DAYTONA_API_KEY=

# Anthropic API key for judge/evaluator agents (if not using ambient auth)
ANTHROPIC_API_KEY=

# Claude Max subscription token for builds and subscription-billed grading
# (mint with `claude setup-token`; preferred over ANTHROPIC_API_KEY)
CLAUDE_CODE_OAUTH_TOKEN=

# E2B API key for the e2b sandbox provider (optional alternative to Daytona)
E2B_API_KEY=

# Cloudflare API token (Zone.DNS edit for codingharness.xyz) for DNS automation
CLOUDFLARE_API_TOKEN=

# z.ai API key for GLM worker-model profiles (driven through Claude Code via
# ANTHROPIC_BASE_URL + ANTHROPIC_AUTH_TOKEN; see config/models.yaml)
ZAI_API_KEY=

# Additional Anthropic-compatible coding endpoints (worker-model profiles).
# Kimi (Moonshot): https://platform.moonshot.ai/console/api-keys
KIMI_API_KEY=
# MiniMax: https://platform.minimax.io/console/access
MINIMAX_API_KEY=
# Qwen (Alibaba Model Studio / DashScope) — key region MUST match the endpoint
# region in config/models.yaml: https://www.alibabacloud.com/help/en/model-studio/get-api-key
DASHSCOPE_API_KEY=
